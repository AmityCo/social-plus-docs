{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "score.schema.json",
  "title": "DocsOps Rubric Score",
  "description": "One score record per (file, rubric_version, scored_at). Appended to evals/scores.jsonl, one JSON object per line.",
  "type": "object",
  "required": ["file", "rubric_version", "scored_at", "scored_by", "dimensions", "total"],
  "additionalProperties": false,
  "properties": {
    "file": { "type": "string", "description": "Repo-relative path." },
    "rubric_version": { "type": "string" },
    "scored_at": { "type": "string", "format": "date-time" },
    "scored_by": { "type": "string", "description": "Agent id. e.g. claude-opus-4-7." },
    "dimensions": {
      "type": "object",
      "required": ["accuracy", "completeness", "cross_platform_parity", "examples", "clarity", "ai_consumability"],
      "properties": {
        "accuracy":              { "$ref": "#/definitions/dimensionScore" },
        "completeness":          { "$ref": "#/definitions/dimensionScore" },
        "cross_platform_parity": { "$ref": "#/definitions/dimensionScore" },
        "examples":              { "$ref": "#/definitions/dimensionScore" },
        "clarity":               { "$ref": "#/definitions/dimensionScore" },
        "ai_consumability":      { "$ref": "#/definitions/dimensionScore" }
      }
    },
    "total": {
      "type": "number",
      "description": "Weighted sum per rubric.json weights. Range 1.0 - 5.0."
    },
    "tier_recommendations": {
      "type": "array",
      "description": "Suggested follow-up task tiers for issues found. e.g. ['A', 'A', 'C']",
      "items": { "enum": ["A", "B", "C"] }
    },
    "notes": { "type": "string" }
  },
  "definitions": {
    "dimensionScore": {
      "type": "object",
      "required": ["score", "rationale"],
      "properties": {
        "score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "rationale": { "type": "string", "description": "One sentence. Cite specific evidence (line numbers, missing item, etc.)." },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional concrete evidence: file:line references, missing API names, etc."
        }
      }
    }
  }
}
