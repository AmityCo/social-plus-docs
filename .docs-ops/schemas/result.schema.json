{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "result.schema.json",
  "title": "DocsOps Task Result",
  "type": "object",
  "required": ["task_id", "agent_id", "status", "completed_at"],
  "additionalProperties": false,
  "properties": {
    "task_id": { "type": "string" },
    "agent_id": { "type": "string", "description": "e.g. claude-opus-4-7, copilot-cli" },
    "status": {
      "enum": ["success", "partial", "failed", "blocked", "no_change_needed"]
    },
    "completed_at": { "type": "string", "format": "date-time" },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validators_run": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "stdout_tail": { "type": "string" },
          "exit_code": { "type": "integer" }
        }
      }
    },
    "rubric_delta": {
      "type": "array",
      "description": "Per-file before/after rubric scores. Populated when rubric_must_not_regress=true.",
      "items": {
        "type": "object",
        "required": ["file", "before", "after"],
        "properties": {
          "file": { "type": "string" },
          "before": { "type": "number" },
          "after": { "type": "number" }
        }
      }
    },
    "report_path": { "type": "string", "description": "Path to the generated report if task.expected_outputs.report_path was set." },
    "notes": { "type": "string", "description": "Free-form. Anything a human reviewer should know." },
    "failure_reason": { "type": "string", "description": "Required when status=failed or blocked." },
    "follow_up_tasks": {
      "type": "array",
      "description": "New task files this task generated (typically when a Tier A scan surfaces Tier B/C work).",
      "items": { "type": "string" }
    }
  }
}
