{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "paths": {
      "@amityco/ts-sdk": ["../../../AmityTypescriptSDK/packages/sdk/src/index.ts"]
    }
  },
  "include": [
    "preamble.d.ts",
    "results/extracted/**/*.ts",
    "results/extracted/**/*.tsx"
  ]
}
