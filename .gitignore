.playwright*/
.DS_Store

# Python
__pycache__/
*.pyc
results/extracted/*.ts
results/extracted/*.tsx

# doc-as-test generated files (TypeScript)
.docs-ops/integration-tests/results/extracted/*.ts
.docs-ops/integration-tests/results/extracted/*.tsx
.docs-ops/integration-tests/results/extracted/_manifest.json

# doc-as-test generated files (Flutter)
.docs-ops/integration-tests/flutter/results/extracted/*.dart
.docs-ops/integration-tests/flutter/results/extracted/_manifest.json
.docs-ops/integration-tests/flutter/.dart_tool/
.docs-ops/integration-tests/flutter/pubspec.lock

# doc-as-test generated files (Android)
.docs-ops/integration-tests/android/results/extracted/*.kt
.docs-ops/integration-tests/android/results/extracted/*.java
.docs-ops/integration-tests/android/results/extracted/_manifest.json
.docs-ops/integration-tests/android/.gradle/
.docs-ops/integration-tests/android/build/
.docs-ops/integration-tests/android/local.properties

# doc-as-test generated files (iOS)
.docs-ops/integration-tests/ios/results/extracted/*.swift
.docs-ops/integration-tests/ios/results/extracted/_manifest.json
.docs-ops/integration-tests/ios/.build/
.docs-ops/integration-tests/ios/.swiftpm/
.docs-ops/integration-tests/ios/Package.resolved
.docs-ops/integration-tests/ios/vendor/
.docs-ops/integration-tests/ios/binary-cache/

# Rubric scorer — pending prompt files are regenerable from page content + template
.docs-ops/rubric-scorer/results/pending/
