```go
func TestCleanDir_RemovesAutoGenerated(t *testing.T) {
	dir := t.TempDir()
	// AUTO-GENERATED file — should be removed
	autoContent := "{/* AUTO-GENERATED by harness gendocs — do not edit manually */}\n<CodeGroup>\n</CodeGroup>\n"
	require.NoError(t, os.WriteFile(filepath.Join(dir, "auto.mdx"), []byte(autoContent), 0o644))
	// Human-edited file — should be kept
	humanContent := "# Human written\n"
	require.NoError(t, os.WriteFile(filepath.Join(dir, "human.mdx"), []byte(humanContent), 0o644))

	removed, err := docgen.CleanDir(dir)
	require.NoError(t, err)
	assert.Equal(t, 1, removed)

	_, errAuto := os.Stat(filepath.Join(dir, "auto.mdx"))
	assert.True(t, os.IsNotExist(errAuto), "auto.mdx should have been removed")
	_, errHuman := os.Stat(filepath.Join(dir, "human.mdx"))
	assert.NoError(t, errHuman, "human.mdx should still exist")
}

func TestCleanDir_EmptyDir(t *testing.T) {
	dir := t.TempDir()
	removed, err := docgen.CleanDir(dir)
	require.NoError(t, err)
	assert.Equal(t, 0, removed)
}
```

- [ ] **Step 2: Run tests to verify they fail**

```bash
cd social-plus-docs/harness && go test ./internal/docgen/... -run TestCleanDir -v
```
Expected: FAIL — `CleanDir undefined`.

- [ ] **Step 3: Implement `CleanDir` in `writer.go`**

Add after the `autoGeneratedMarker` constant:
```go
// CleanDir removes all AUTO-GENERATED MDX files from outDir (recursively).
// Returns the count of removed files. Human-edited files are left untouched.
func CleanDir(outDir string) (removed int, err error) {
	return removed, filepath.WalkDir(outDir, func(path string, d os.DirEntry, walkErr error) error {
		if walkErr != nil || d.IsDir() {
			return walkErr
		}
		if !strings.HasSuffix(path, ".mdx") {
			return nil
		}
		content, readErr := os.ReadFile(path)
		if readErr != nil {
			return readErr
		}
		if strings.Contains(string(content), autoGeneratedMarker) {
			if delErr := os.Remove(path); delErr != nil {
				return delErr
			}
			removed++
		}
		return nil
	})
}
```

